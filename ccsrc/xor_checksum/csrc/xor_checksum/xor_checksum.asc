#include <torch/torch.h>
#include <torch/library.h>
#include "torch_npu/csrc/core/npu/NPUStream.h"
#include "torch_npu/csrc/framework/OpCommand.h"
#include "kernel_operator.h"
#include "platform/platform_ascendc.h"
#include "tiling/tiling_api.h"
#include <cstdint>
#include <algorithm>

namespace msprobe {
namespace XorChecksum {

constexpr uint32_t kOutputBufferSlots = 128;
constexpr uint32_t kBytesPerWord = 8;
constexpr uint32_t kBytesPerBlock = 32;
constexpr uint32_t kMinimumStableMultiCoreNum = 3U;
constexpr uint32_t kXorTypeSize = 2U;
constexpr uint32_t kXorDenomBase = 2U;
constexpr uint64_t kScalarThreshold = 16U;

inline uint64_t roundDownPow2(uint64_t n)
{
    if (n == 0) return 0;
    n |= n >> 1;
    n |= n >> 2;
    n |= n >> 4;
    n |= n >> 8;
    n |= n >> 16;
    n |= n >> 32;
    return n - (n >> 1);
}

std::tuple<uint64_t, uint64_t, uint64_t, uint64_t, uint64_t, uint64_t, uint64_t, uint64_t>
calc_tiling_params(uint64_t totalElements)
{
    auto ascendcPlatform = platform_ascendc::PlatformAscendCManager::GetInstance();
    uint64_t coreNum = static_cast<uint64_t>(ascendcPlatform->GetCoreNumAiv());
    TORCH_CHECK(coreNum > 0, "coreNum must be positive.");

    uint64_t ubSize;
    ascendcPlatform->GetCoreMemSize(platform_ascendc::CoreMemType::UB, ubSize);
    constexpr uint64_t kUbReserved = 2048;
    uint64_t availUb = ubSize - kUbReserved;

    uint32_t maxLiveNodeCount = 0;
    uint32_t extraBuf = 0;
    AscendC::GetXorTmpBufferFactorSize(kXorTypeSize, maxLiveNodeCount, extraBuf);

    uint64_t denom = kXorDenomBase + static_cast<uint64_t>(maxLiveNodeCount);
    uint64_t tileComputeBufChunkBytes = 0;
    if (availUb > extraBuf && denom > 0) {
        tileComputeBufChunkBytes = (availUb - extraBuf) / denom;
    }
    uint64_t bufUint16 = tileComputeBufChunkBytes / sizeof(uint16_t);
    uint64_t bufUint16Pow2 = roundDownPow2(bufUint16);
    if (bufUint16Pow2 < kScalarThreshold) {
        bufUint16Pow2 = kScalarThreshold;
    }
    tileComputeBufChunkBytes = bufUint16Pow2 * sizeof(uint16_t);
    uint64_t tileSize = tileComputeBufChunkBytes;
    uint64_t tmpBufSize = static_cast<uint64_t>(maxLiveNodeCount) * tileComputeBufChunkBytes + extraBuf;

    uint64_t totalBytes = totalElements;
    uint64_t mainBytes = (totalBytes / kBytesPerBlock) * kBytesPerBlock;
    uint64_t tailBytes = totalBytes - mainBytes;
    uint64_t mainBlocks = mainBytes / kBytesPerBlock;

    uint64_t chunkBytes = totalBytes / coreNum;
    if (chunkBytes == 0) {
        chunkBytes = kBytesPerBlock;
    }

    constexpr uint32_t kInternalPartialSlotCount = 64U;
    uint64_t realCoreNum = 1;
    if (mainBytes > 0) {
        uint64_t legalCoreNum = std::min<uint64_t>(std::min<uint64_t>(coreNum, kInternalPartialSlotCount), mainBlocks);
        uint64_t recommendedMinSliceBytes = std::max(chunkBytes, static_cast<uint64_t>(kBytesPerBlock));
        uint64_t perfCoreNum = std::max<uint64_t>(1, mainBytes / recommendedMinSliceBytes);
        realCoreNum = std::max<uint64_t>(1, std::min(legalCoreNum, perfCoreNum));
        if (realCoreNum < kMinimumStableMultiCoreNum) {
            realCoreNum = 1;
        }
    }

    uint64_t baseBlocksPerCore = mainBlocks / realCoreNum;
    uint64_t extraBlocks = mainBlocks % realCoreNum;
    TORCH_CHECK(tmpBufSize <= UINT32_MAX, "tmpBufSize exceeds uint32_t range");
    return std::make_tuple(totalBytes, mainBytes, tailBytes, realCoreNum,
        baseBlocksPerCore, extraBlocks, tileSize, tmpBufSize);
}

__aicore__ inline int64_t AssembleLittleEndian64(const uint16_t lanes[4])
{
    return static_cast<int64_t>(lanes[0]) | (static_cast<int64_t>(lanes[1]) << 16) |
        (static_cast<int64_t>(lanes[2]) << 32) | (static_cast<int64_t>(lanes[3]) << 48);
}

class XorChecksumKernel {
public:
    __aicore__ XorChecksumKernel() = default;

    __aicore__ void Init(GM_ADDR x, GM_ADDR y,
        uint64_t totalBytes, uint64_t mainBytes, uint64_t tailBytes,
        uint64_t realCoreNum,
        uint64_t baseBlocksPerCore, uint64_t extraBlocks,
        uint64_t tileSize, uint64_t tmpBufSize)
    {
        totalBytes_ = totalBytes;
        mainBytes_ = mainBytes;
        tailBytes_ = tailBytes;
        realCoreNum_ = realCoreNum;
        baseBlocksPerCore_ = baseBlocksPerCore;
        extraBlocks_ = extraBlocks;
        tileSize_ = tileSize;
        tmpBufSize_ = static_cast<uint32_t>(tmpBufSize);
        blockIdx_ = AscendC::GetBlockIdx();
        inputBase_ = reinterpret_cast<__gm__ uint8_t*>(x);
        outputGm_.SetGlobalBuffer(reinterpret_cast<__gm__ int64_t*>(y), kOutputBufferSlots);
        outputBase_ = reinterpret_cast<__gm__ int64_t*>(y);
        pipe_.InitBuffer(inQueue_, 1, static_cast<uint32_t>(tileSize));
        pipe_.InitBuffer(resultBuf_, static_cast<uint32_t>(tileSize));
        if (tmpBufSize_ > 0) {
            pipe_.InitBuffer(tmpBuf_, tmpBufSize_);
        }
    }

    __aicore__ void ProcessDirect()
    {
        if (blockIdx_ == 0) {
            WriteSlot(0, ComputeChecksum(0, totalBytes_, true));
        }
    }

    __aicore__ void ProcessMultiCore()
    {
        if (blockIdx_ >= realCoreNum_) {
            return;
        }

        const uint64_t mainStart = GetSliceStart(blockIdx_);
        const uint64_t sliceBytes = GetSliceBytes(blockIdx_);
        const int64_t partialChecksum = ComputeChecksum(mainStart, sliceBytes, false);
        const int64_t tailChecksum = blockIdx_ == 0 ? ComputeChecksum(mainBytes_, tailBytes_, true) : 0LL;
        WriteSlot(blockIdx_, partialChecksum);
        AscendC::SyncAll();
        if (blockIdx_ != 0) {
            return;
        }

        int64_t checksum = 0;
        for (uint32_t slot = 0; slot < realCoreNum_; ++slot) {
            checksum ^= ReadSlot(slot);
        }
        checksum ^= tailChecksum;
        WriteSlot(realCoreNum_, checksum);
    }

private:
    __aicore__ static void FoldWord(const uint8_t wordBytes[8], uint16_t laneXor[4])
    {
        const uint16_t lane0 = static_cast<uint16_t>(wordBytes[0]) | (static_cast<uint16_t>(wordBytes[1]) << 8);
        const uint16_t lane1 = static_cast<uint16_t>(wordBytes[2]) | (static_cast<uint16_t>(wordBytes[3]) << 8);
        const uint16_t lane2 = static_cast<uint16_t>(wordBytes[4]) | (static_cast<uint16_t>(wordBytes[5]) << 8);
        const uint16_t lane3 = static_cast<uint16_t>(wordBytes[6]) | (static_cast<uint16_t>(wordBytes[7]) << 8);
        laneXor[0] ^= lane0;
        laneXor[1] ^= lane1;
        laneXor[2] ^= lane2;
        laneXor[3] ^= lane3;
    }

    __aicore__ uint64_t GetSliceStart(uint32_t blockIdx) const
    {
        const uint64_t leadingExtraBlocks = blockIdx < extraBlocks_ ? blockIdx : extraBlocks_;
        return (static_cast<uint64_t>(blockIdx) * baseBlocksPerCore_ + leadingExtraBlocks) * kBytesPerBlock;
    }

    __aicore__ uint64_t GetSliceBytes(uint32_t blockIdx) const
    {
        const uint64_t blockCount = baseBlocksPerCore_ + (blockIdx < extraBlocks_ ? 1U : 0U);
        return blockCount * kBytesPerBlock;
    }

    __aicore__ static int64_t ScalarReduceChunk(const AscendC::LocalTensor<uint16_t>& tensor, uint64_t uint16Count)
    {
        uint16_t laneXor[4] = {0, 0, 0, 0};
        uint64_t numWords = uint16Count / 4;
        for (uint64_t i = 0; i < numWords; ++i) {
            uint64_t base = i * 4;
            laneXor[0] ^= tensor.GetValue(base + 0);
            laneXor[1] ^= tensor.GetValue(base + 1);
            laneXor[2] ^= tensor.GetValue(base + 2);
            laneXor[3] ^= tensor.GetValue(base + 3);
        }
        uint64_t remainder = uint16Count % 4;
        for (uint64_t i = 0; i < remainder; ++i) {
            laneXor[i] ^= tensor.GetValue(numWords * 4 + i);
        }
        return AssembleLittleEndian64(laneXor);
    }

    __aicore__ int64_t ComputeChecksum(uint64_t startOffset, uint64_t bytesToProcess, bool padTail)
    {
        uint16_t laneXor[4] = {0, 0, 0, 0};
        uint64_t remaining = bytesToProcess;
        uint64_t offset = startOffset;

        bool hasTmp = (tmpBufSize_ > 0);
        AscendC::LocalTensor<uint8_t> tmpTensor;
        if (hasTmp) {
            tmpTensor = tmpBuf_.Get<uint8_t>();
        }
        AscendC::LocalTensor<uint16_t> tileComputeBuf = resultBuf_.Get<uint16_t>();

        while (remaining >= kBytesPerWord) {
            uint64_t loadBytes = remaining < tileSize_ ? remaining : tileSize_;
            loadBytes = (loadBytes / kBytesPerBlock) * kBytesPerBlock;
            if (loadBytes < kBytesPerWord) {
                loadBytes = kBytesPerWord;
            }
            uint64_t loadUint16 = loadBytes / sizeof(uint16_t);

            AscendC::LocalTensor<uint16_t> tileInputBuf = inQueue_.AllocTensor<uint16_t>();
            AscendC::GlobalTensor<uint16_t> gmSlice;
            gmSlice.SetGlobalBuffer(reinterpret_cast<__gm__ uint16_t*>(inputBase_ + offset), loadUint16);
            AscendC::DataCopyExtParams copyParams = {1, static_cast<uint32_t>(loadBytes), 0, 0, 0};
            AscendC::DataCopyPadExtParams<uint16_t> padParams{false, 0, 0, 0};
            AscendC::DataCopyPad(tileInputBuf, gmSlice, copyParams, padParams);
            AscendC::SetFlag<AscendC::HardEvent::MTE2_S>(0);
            AscendC::WaitFlag<AscendC::HardEvent::MTE2_S>(0);

            uint64_t count = loadUint16;
            uint64_t level = 0;

            while (count > kScalarThreshold) {
                if (count & 0x1FULL) {
                    uint64_t padded = (count + 31) & ~31ULL;
                    if ((level & 1U) == 0) {
                        for (uint64_t i = count; i < padded; i++) {
                            tileInputBuf.SetValue(i, 0);
                        }
                    } else {
                        for (uint64_t i = count; i < padded; i++) {
                            tileComputeBuf.SetValue(i, 0);
                        }
                    }
                    count = padded;
                    AscendC::SetFlag<AscendC::HardEvent::MTE2_S>(0);
                    AscendC::WaitFlag<AscendC::HardEvent::MTE2_S>(0);
                }
                uint64_t half = count / 2;
                level++;
                if (hasTmp) {
                    if ((level & 1U) == 0) {
                        AscendC::Xor<uint16_t, false>(tileInputBuf, tileComputeBuf, tileComputeBuf[half], tmpTensor,
                            static_cast<uint32_t>(half));
                    } else {
                        AscendC::Xor<uint16_t, false>(tileComputeBuf, tileInputBuf, tileInputBuf[half], tmpTensor,
                            static_cast<uint32_t>(half));
                    }
                } else {
                    if ((level & 1U) == 0) {
                        AscendC::Xor<uint16_t, false>(tileInputBuf, tileComputeBuf, tileComputeBuf[half],
                            static_cast<uint32_t>(half));
                    } else {
                        AscendC::Xor<uint16_t, false>(tileComputeBuf, tileInputBuf, tileInputBuf[half],
                            static_cast<uint32_t>(half));
                    }
                }
                AscendC::PipeBarrier<PIPE_ALL>();
                count = half;
            }

            int64_t vecResult;
            if ((level & 1U) == 0) {
                vecResult = ScalarReduceChunk(tileInputBuf, count);
            } else {
                vecResult = ScalarReduceChunk(tileComputeBuf, count);
            }
            laneXor[0] ^= static_cast<uint16_t>(vecResult);
            laneXor[1] ^= static_cast<uint16_t>(vecResult >> 16);
            laneXor[2] ^= static_cast<uint16_t>(vecResult >> 32);
            laneXor[3] ^= static_cast<uint16_t>(vecResult >> 48);

            inQueue_.FreeTensor(tileInputBuf);
            offset += loadBytes;
            remaining -= loadBytes;
        }

        if (padTail && remaining > 0) {
            uint8_t wordBytes[kBytesPerWord];
            uint64_t tailLen = remaining;
            AscendC::LocalTensor<uint8_t> tailLocal = inQueue_.AllocTensor<uint8_t>();
            AscendC::GlobalTensor<uint8_t> srcSlice;
            srcSlice.SetGlobalBuffer(inputBase_ + offset, static_cast<uint32_t>(tailLen));
            AscendC::DataCopyExtParams copyParams = {1, static_cast<uint32_t>(tailLen), 0, 0, 0};
            AscendC::DataCopyPadExtParams<uint8_t> padParams{false, 0, 0, 0};
            AscendC::DataCopyPad(tailLocal, srcSlice, copyParams, padParams);
            AscendC::SetFlag<AscendC::HardEvent::MTE2_S>(0);
            AscendC::WaitFlag<AscendC::HardEvent::MTE2_S>(0);
            for (uint64_t i = 0; i < tailLen; ++i) {
                wordBytes[i] = tailLocal.GetValue(i);
            }
            for (uint64_t i = tailLen; i < kBytesPerWord; ++i) {
                wordBytes[i] = 0;
            }
            inQueue_.FreeTensor(tailLocal);
            FoldWord(wordBytes, laneXor);
        }
        return AssembleLittleEndian64(laneXor);
    }

    __aicore__ void WriteSlot(uint32_t idx, int64_t checksum)
    {
#if __NPU_ARCH__ >= 3510
        AscendC::WriteGmByPassDCache<int64_t>(outputBase_ + idx, checksum);
#else
        AscendC::LocalTensor<int64_t> tmpLocal = inQueue_.AllocTensor<int64_t>();
        tmpLocal.SetValue(0, checksum);
        AscendC::DataCopyExtParams copyParams = {1, sizeof(int64_t), 0, 0, 0};
        AscendC::DataCopyPad(outputGm_[idx], tmpLocal, copyParams);
        AscendC::SetFlag<AscendC::HardEvent::MTE3_S>(0);
        AscendC::WaitFlag<AscendC::HardEvent::MTE3_S>(0);
        inQueue_.FreeTensor(tmpLocal);
#endif
    }

    __aicore__ int64_t ReadSlot(uint32_t idx)
    {
        AscendC::LocalTensor<int64_t> tmpLocal = inQueue_.AllocTensor<int64_t>();
        AscendC::DataCopyExtParams copyParams = {1, sizeof(int64_t), 0, 0, 0};
        AscendC::DataCopyPadExtParams<int64_t> padParams{false, 0, 0, 0};
        AscendC::DataCopyPad(tmpLocal, outputGm_[idx], copyParams, padParams);
        AscendC::SetFlag<AscendC::HardEvent::MTE2_S>(0);
        AscendC::WaitFlag<AscendC::HardEvent::MTE2_S>(0);
        int64_t result = tmpLocal.GetValue(0);
        inQueue_.FreeTensor(tmpLocal);
        return result;
    }

    AscendC::TPipe pipe_;
    AscendC::TQue<AscendC::QuePosition::VECIN, 1> inQueue_;
    AscendC::TBuf<AscendC::TPosition::VECCALC> resultBuf_;
    AscendC::TBuf<AscendC::TPosition::VECCALC> tmpBuf_;
    __gm__ uint8_t* inputBase_ = nullptr;
    AscendC::GlobalTensor<int64_t> outputGm_;
    __gm__ int64_t* outputBase_ = nullptr;
    uint64_t totalBytes_ = 0;
    uint64_t mainBytes_ = 0;
    uint64_t tailBytes_ = 0;
    uint64_t realCoreNum_ = 1;
    uint64_t baseBlocksPerCore_ = 0;
    uint64_t extraBlocks_ = 0;
    uint64_t tileSize_ = 0;
    uint32_t tmpBufSize_ = 0;
    uint32_t blockIdx_ = 0;
};

__global__ __aicore__ void xor_checksum_single_core(
    GM_ADDR x, GM_ADDR y,
    uint64_t totalBytes, uint64_t mainBytes, uint64_t tailBytes,
    uint64_t realCoreNum,
    uint64_t baseBlocksPerCore, uint64_t extraBlocks,
    uint64_t tileSize, uint64_t tmpBufSize)
{
    KERNEL_TASK_TYPE_DEFAULT(KERNEL_TYPE_MIX_AIV_1_0);
    XorChecksumKernel kernel;
    kernel.Init(x, y,
        totalBytes, mainBytes, tailBytes, realCoreNum,
        baseBlocksPerCore, extraBlocks, tileSize, tmpBufSize);
    kernel.ProcessDirect();
}

__global__ __aicore__ void xor_checksum_multi_core(
    GM_ADDR x, GM_ADDR y,
    uint64_t totalBytes, uint64_t mainBytes, uint64_t tailBytes,
    uint64_t realCoreNum,
    uint64_t baseBlocksPerCore, uint64_t extraBlocks,
    uint64_t tileSize, uint64_t tmpBufSize)
{
    KERNEL_TASK_TYPE_DEFAULT(KERNEL_TYPE_MIX_AIV_1_0);
    XorChecksumKernel kernel;
    kernel.Init(x, y,
        totalBytes, mainBytes, tailBytes, realCoreNum,
        baseBlocksPerCore, extraBlocks, tileSize, tmpBufSize);
    kernel.ProcessMultiCore();
}

TORCH_LIBRARY_FRAGMENT(EXTENSION_MODULE_NAME, m)
{
    m.def("xor_checksum(Tensor x) -> Tensor");
}

torch::Tensor xor_checksum_meta(const torch::Tensor& x)
{
    return torch::empty({1}, torch::TensorOptions().dtype(torch::kInt64).device(torch::kMeta));
}

TORCH_LIBRARY_IMPL(EXTENSION_MODULE_NAME, Meta, m)
{
    m.impl("xor_checksum", xor_checksum_meta);
}

torch::Tensor xor_checksum_npu(const torch::Tensor& x)
{
    TORCH_CHECK(x.scalar_type() == torch::kUInt8, "XorChecksum only supports uint8 dtype.");
    auto x_contig = x.contiguous();

    const c10::OptionalDeviceGuard guard(x_contig.device());

    int64_t totalElements = x_contig.numel();
    if (totalElements <= 0) {
        auto result = torch::zeros({1}, torch::TensorOptions().dtype(torch::kInt64).device(x_contig.device()));
        return result;
    }

    auto out = torch::empty({kOutputBufferSlots}, torch::TensorOptions().dtype(torch::kInt64).device(x_contig.device()));
    auto stream = c10_npu::getCurrentNPUStream().stream(false);
    uint64_t totalBytes, mainBytes, tailBytes, realCoreNum;
    uint64_t baseBlocksPerCore, extraBlocks, tileSize, tmpBufSize;
    std::tie(totalBytes, mainBytes, tailBytes, realCoreNum,
        baseBlocksPerCore, extraBlocks, tileSize, tmpBufSize) =
        calc_tiling_params(static_cast<uint64_t>(totalElements));

    GM_ADDR x_ptr = (GM_ADDR)x_contig.data_ptr();
    GM_ADDR out_ptr = (GM_ADDR)out.data_ptr();

    auto acl_call = [=]() -> int {
        if (realCoreNum == 1) {
            xor_checksum_single_core<<<1, nullptr, stream>>>(
                x_ptr, out_ptr,
                totalBytes, mainBytes, tailBytes, realCoreNum,
                baseBlocksPerCore, extraBlocks, tileSize, tmpBufSize);
        } else {
            xor_checksum_multi_core<<<realCoreNum, nullptr, stream>>>(
                x_ptr, out_ptr,
                totalBytes, mainBytes, tailBytes, realCoreNum,
                baseBlocksPerCore, extraBlocks, tileSize, tmpBufSize);
        }
        return 0;
    };

    at_npu::native::OpCommand::RunOpApi("XorChecksum", acl_call);

    if (realCoreNum > 1) {
        return out[realCoreNum].unsqueeze(0);
    }
    return out[0].unsqueeze(0);
}

TORCH_LIBRARY_IMPL(EXTENSION_MODULE_NAME, PrivateUse1, m)
{
    m.impl("xor_checksum", xor_checksum_npu);
}

} // namespace XorChecksum
} // namespace msprobe
